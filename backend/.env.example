# --- Veritabani ---
# Varsayilan SQLite (backend/data/epdk.db). PostgreSQL icin:
# DATABASE_URL=postgresql+psycopg2://user:pass@localhost:5432/epdk
# DATABASE_URL=sqlite:///./data/epdk.db

# --- Zamanlayici (her gun bu saatte senkron TETIKLENIR; captcha'yi yine sen cozersin) ---
SYNC_HOUR=8
SYNC_MINUTE=30
TIMEZONE=Europe/Istanbul
SCHEDULER_ENABLED=true

# --- Scraper ---
# Captcha icin tarayici GORUNUR olmali; headless=true captcha'yi cozemezsin.
HEADLESS=false
ROWS_PER_PAGE=50
REQUEST_DELAY_MS=400
CAPTCHA_WAIT_TIMEOUT_S=600
# 0 = tum sayfalar; test icin ornegin 2
MAX_PAGES=0

# --- Koordinat ---
# 'wgs84' (kesifte dogrulandi) | 'ed50' (EPDK eski verisi icin dene ve dogrula)
COORD_DATUM=wgs84
